# Database
DATABASE_URL="file:./dev.db"

# YouTube API
# Get your API key from: https://console.cloud.google.com/
# 1. Go to Google Cloud Console
# 2. Create a project and enable YouTube Data API v3
# 3. Create credentials (API key)
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY_HERE"

# LLM Provider Selection
# Options: "local" (uses Ollama) or "minimax" (uses MiniMax API)
LLM_PROVIDER="local"

# Local LLM (Ollama) - Used when LLM_PROVIDER="local"
# Install Ollama: https://ollama.ai
# Pull a model: ollama pull qwen2.5:14b (or your preferred model)
# Start server: ollama serve
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:14b"

# MiniMax API - Used when LLM_PROVIDER="minimax"
# Get your API key from: https://platform.minimaxi.com/
MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY_HERE"
MINIMAX_BASE_URL="https://api.minimax.io/v1"
MINIMAX_MODEL="MiniMax-M2.7"

# Sentry Error Tracking (Optional)
# Get your DSN from: https://sentry.io (free tier available)
# When not set, Sentry gracefully degrades — no errors are sent
SENTRY_DSN=""

# GitHub API Token (Optional but recommended)
# Get your token from: https://github.com/settings/tokens
# Required scope: repo (for private repos) or public_repo (for public repos only)
# Without this token, GitHub API is limited to 60 requests/hour
GITHUB_TOKEN="YOUR_GITHUB_TOKEN_HERE"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
