// Prisma schema for YouTube Knowledge Base

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// YouTube Channel
model Channel {
  id          String   @id @default(cuid())
  youtubeId   String   @unique
  name        String
  description String?
  thumbnail   String?
  isActive    Boolean  @default(true)
  lastFetched DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videos Video[]
  syncQueueItems SyncQueue[]
}

// Video
model Video {
  id            String   @id @default(cuid())
  youtubeId     String   @unique
  channelId     String
  title         String
  description   String?
  thumbnail     String?
  duration      Int?
  publishedAt   DateTime
  viewCount     Int      @default(0)
  fetchedAt     DateTime @default(now())
  hasTranscript Boolean  @default(false)
  transcript    String?  // Store full transcript text

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  blogPosts BlogPost[]

  @@index([channelId])
  @@index([publishedAt])
}

// Generated Blog Post
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @default("") // Markdown content
  excerpt     String?
  coverImage  String?
  status      String   @default("draft") // draft, published
  sourceType  String   @default("youtube") // youtube, github, web
  sourceUrl   String?  // Original URL
  generatedAt DateTime @default(now())
  publishedAt DateTime?
  updatedAt   DateTime @updatedAt

  // Language support for bilingual content
  language      String  @default("zh") // zh (Chinese), en (English), bilingual
  translatedZh  String? // Chinese translation of content
  translatedEn  String? // English translation of content
  titleZh       String? // Chinese title
  titleEn       String? // English title

  // Relations
  videoId           String?          @unique
  video             Video?           @relation(fields: [videoId], references: [id])

  knowledgeSourceId String?
  knowledgeSource   KnowledgeSource? @relation(fields: [knowledgeSourceId], references: [id])

  categoryId        String?
  category          Category?        @relation(fields: [categoryId], references: [id])
  tags              Tag[]

  @@index([slug])
  @@index([status])
  @@index([language]) // For filtered queries by language
  @@index([sourceType])
  @@index([publishedAt])
  @@index([knowledgeSourceId]) // For querying by knowledge source
  @@index([generatedAt]) // For sorting
  @@index([sourceUrl]) // For URL deduplication lookups
  @@index([status, sourceType]) // Composite index for filtered lists
}

// Knowledge Ingestion Engine Models
model ProjectGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  tags        String?
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources     KnowledgeSource[]
}

model KnowledgeSource {
  id               String   @id @default(cuid())
  sourceType       String   // YOUTUBE, GITHUB, WEB
  externalId       String?
  sourceUrl        String
  title            String
  description      String?
  content          String?  @default("")
  processedContent String?  @default("")
  thumbnail        String?
  author           String?
  tags             String?
  status           String   @default("pending") // pending, processing, completed, failed
  errorMessage     String?
  generatedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  projectGroupId   String?
  projectGroup     ProjectGroup? @relation(fields: [projectGroupId], references: [id])

  blogPosts         BlogPost[]

  @@index([sourceType])
  @@index([status])
  @@index([sourceUrl]) // For deduplication checks
  @@index([generatedAt]) // For sorting
}


// Knowledge Taxonomy
model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  blogs     BlogPost[]
}

model Tag {
  id    String     @id @default(cuid())
  name  String     @unique
  blogs BlogPost[]
}

// Settings
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// Sync Queue - persisted to database so it survives server restarts
model SyncQueue {
  id                 String    @id @default(cuid())
  channelId          String
  channelName        String
  channelThumbnail   String?
  status             String    @default("pending") // pending, processing, completed, failed
  addedAt            DateTime  @default(now())
  startedAt           DateTime?
  completedAt         DateTime?
  progressCurrent     Int       @default(0)
  progressTotal       Int       @default(5)
  currentVideoTitle   String?
  resultNewVideos     Int?
  resultBlogsGenerated Int?
  resultSkipped       Int?
  resultErrors        String?   // JSON array of error strings
  error               String?

  channel            Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([channelId])
}
